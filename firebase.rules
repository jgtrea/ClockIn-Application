rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /user_employee_data/{docId} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true
        || (resource.data.email != null && request.auth.token.email == resource.data.email)
        || request.auth.token.email == 'hello@gmail.com'
      );

      allow create, update, delete: if request.auth != null && (
        request.auth.token.admin == true || request.auth.token.email == 'hello@gmail.com'
      );
    }

    match /users/{userId} {
      allow read, update: if request.auth != null && (
        request.auth.uid == userId
        || request.auth.token.admin == true
        || request.auth.token.email == 'hello@gmail.com'
      );
      allow create: if request.auth != null && request.auth.uid == userId;
    }
  }
}
